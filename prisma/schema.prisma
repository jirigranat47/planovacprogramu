// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String   @id @default(cuid())
  name        String
  startTime   DateTime
  endTime     DateTime
  description String?
  tracks      Track[]
  activities  Activity[]
  anchors     AnchorPoint[]
  users       EventUser[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Track {
  id         String     @id @default(cuid())
  name       String
  color      String?
  event      Event      @relation(fields: [eventId], references: [id])
  eventId    String
  activities Activity[]
}

model Activity {
  id          String    @id @default(cuid())
  name        String
  startTime   DateTime? // Optional pro zásobník
  duration    Int       // v minutách
  description String?
  url         String?
  category    String?
  track       Track?    @relation(fields: [trackId], references: [id])
  trackId     String?
  event       Event     @relation(fields: [eventId], references: [id])
  eventId     String
  subtasks    Subtask[]
  
  responsibleUsers  User[]   @relation("ActivityResponsible")
}

model Subtask {
  id         String   @id @default(cuid())
  text       String
  isDone     Boolean  @default(false)
  activity   Activity @relation(fields: [activityId], references: [id])
  activityId String
}

model AnchorPoint {
  id        String   @id @default(cuid())
  name      String
  startTime DateTime
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
}

// --- NeXTAUTH a Uzivatele ---

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  
  eventUsers       EventUser[]
  managedActivities Activity[]  @relation("ActivityResponsible")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model EventUser {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}
